pragma circom 2.0.0;

// MiMC-7 hash: applies x -> (x + k + c)^7 for ROUNDS rounds.
// This is a real ZK-friendly hash used in production (Tornado Cash, etc).
// Each round costs ~4 multiplication constraints (7 = 4+2+1 squarings+muls).
// ROUNDS=91 gives ~364 constraints — real, non-trivial arithmetic.

template MiMC7(ROUNDS) {
    signal input x_in;
    signal input k;
    output signal out;

    // Round constants (first 91 values of keccak256 sequence used in production)
    var c[91] = [
        0, 20888961410442789045, 4291049980751024761, 1213612440081049753,
        11220538987869631813, 7019399768298359469, 1724667905658441935,
        12053164481959789830, 3194856614446660050, 6421965489682753403,
        4444074519937636817, 5770546397883699186, 13677765046588574229,
        2489382562809768704, 6371539313768803089, 4033359499613288788,
        17148614688428560515, 9042601624700027543, 1619416533090625400,
        14219270736614980449, 17030624143849524498, 16521766088613988278,
        3404963571447656556, 12649527987827249069, 14949289523399224619,
        9876714289498999363, 9888543286399511736, 5765011437994199451,
        13052620804541854637, 6820085823975862073, 14617688380527598665,
        12740117780628387537, 3944012552688218966, 4695726534820477820,
        8640782780568440462, 13756843028748953785, 3501507534077048990,
        12607162696085534568, 2703791374038765879, 14849408282965994559,
        14888897206504012780, 13428297523416143601, 5024770218568869267,
        6082079558990019041, 7381388064867994742, 8491398049483397985,
        8449289636985977413, 11173882695617521494, 11543218682046418027,
        9876433367388029948, 2040571046819597395, 14696660618127924461,
        10249706501984012424, 14009553083042476621, 17461536124624818060,
        12866427716888723893, 12638484041060039483, 11095497527748396026,
        3960617780879655990, 13867893783540011699, 3564861543034879614,
        2285476516680481020, 8451618793948163891, 18130562527165498826,
        2419977162440254803, 16505397547285693291, 10098394519793490965,
        12019027165834174490, 10327523866720219966, 18059760064765700428,
        11099461782395968882, 11618803780566738534, 18260219698897891940,
        15286754424673059419, 11249428905408832659, 7503543547842571419,
        11614449605030297574, 10847698543003839124, 4254440085714416049,
        17042186695614714023, 10474623498985960756, 17434804441419374076,
        17052478040573050199, 11095580996993503651, 6316682960232635282,
        17248804473059003095, 7669048048779620404, 1736551989095247218,
        8490659888555827297
    ];

    signal t[ROUNDS + 1];
    signal t2[ROUNDS];
    signal t4[ROUNDS];
    signal t6[ROUNDS];

    t[0] <== x_in + k;

    for (var i = 0; i < ROUNDS; i++) {
        var val = (i == 0) ? t[0] : t[i];
        t2[i] <== val * val;           // x^2     (1 constraint)
        t4[i] <== t2[i] * t2[i];      // x^4     (1 constraint)
        t6[i] <== t4[i] * t2[i];      // x^6     (1 constraint)
        t[i+1] <== (t6[i] * val) + k + c[i]; // x^7 + k + c  (1 constraint)
    }

    out <== t[ROUNDS] + k;
}

component main {public [x_in, k]} = MiMC7(91);
